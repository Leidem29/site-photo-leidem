---
import Layout from '../layouts/Layout.astro';
import contactContent from '../content/contact.json';
---

<Layout>
	<section class="contact-page">
		<div class="contact-grid">
			<div class="contact-info">
				<h1>{contactContent.title}</h1>
				<p>
					{contactContent.intro}
				</p>
				<div class="info-links">
					<a href={`mailto:${contactContent.email}`}>{contactContent.email}</a>
					<a
						href={`https://instagram.com/${contactContent.instagram.replace(/^@/, '')}`}
						target="_blank"
						rel="noreferrer">{contactContent.instagram}</a
					>
				</div>
			</div>

			<form class="contact-form" name="contact" method="POST" data-netlify="true">
				<input type="hidden" name="form-name" value="contact" />

				<label for="name">Nom</label>
				<input id="name" name="name" type="text" autocomplete="name" required />

				<label for="email">Email</label>
				<input id="email" name="email" type="email" autocomplete="email" required />

				<label for="session-type">Type de seance</label>
				<select id="session-type" name="session-type" required>
					<option value="" selected disabled>Selectionnez une prestation</option>
					<option value="mariage">Mariage</option>
					<option value="portrait">Portrait</option>
					<option value="famille-grossesse">Famille & Grossesse</option>
					<option value="autre">Autre projet</option>
				</select>

				<label for="message">Message</label>
				<textarea id="message" name="message" rows="4" required></textarea>

				<button type="submit">Envoyer</button>
			</form>
		</div>
	</section>
</Layout>

<style>
	.contact-page {
		max-width: 1120px;
		margin: 0 auto;
		padding: 8.5rem 1.5rem 7rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3.5rem;
	}

	.contact-info h1 {
		margin: 0 0 1.2rem;
		font-size: clamp(2rem, 4.5vw, 3.6rem);
		font-weight: 500;
	}

	.contact-info p {
		margin: 0;
		max-width: 560px;
		line-height: 1.9;
		color: #2c2c2c;
	}

	.info-links {
		margin-top: 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.info-links a {
		color: #181818;
		text-decoration: none;
		font-family: 'Montserrat', 'Inter', sans-serif;
		font-size: 0.88rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 300;
		transition: opacity 0.2s ease;
	}

	.info-links a:hover {
		opacity: 0.65;
	}

	.contact-form {
		display: grid;
		gap: 1.25rem;
	}

	.contact-form label {
		font-family: 'Montserrat', 'Inter', sans-serif;
		font-size: 0.76rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #4a4a4a;
	}

	.contact-form input,
	.contact-form select,
	.contact-form textarea {
		border: none;
		border-bottom: 1px solid #d9d9d9;
		background: transparent;
		padding: 0.55rem 0.1rem 0.7rem;
		font: inherit;
		color: #161616;
		outline: none;
		border-radius: 0;
	}

	.contact-form textarea {
		resize: vertical;
		min-height: 6.2rem;
	}

	.contact-form input:focus,
	.contact-form select:focus,
	.contact-form textarea:focus {
		border-bottom-color: #222222;
	}

	.contact-form button {
		margin-top: 0.8rem;
		justify-self: start;
		border: 1px solid #171717;
		background: transparent;
		color: #171717;
		padding: 0.75rem 1.7rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.76rem;
		font-family: 'Montserrat', 'Inter', sans-serif;
		font-weight: 300;
		cursor: pointer;
		transition: background-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
	}

	.contact-form button:hover {
		background: #171717;
		color: #ffffff;
		opacity: 0.92;
	}

	@media (min-width: 940px) {
		.contact-grid {
			grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
			align-items: start;
			gap: 5rem;
		}
	}
</style>
